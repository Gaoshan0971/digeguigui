/* pages/identify/identify.wxss — 拍照识龟 */
.page { padding-bottom: 40px; min-height: 100vh; }

/* Hero */
.hero { text-align: center; padding: 40px 20px 24px; }
.hero-icon { font-size: 56px; display: block; margin-bottom: 8px; }
.hero-title { font-size: 26px; font-weight: 800; color: var(--text); display: block; letter-spacing: 1px; }
.hero-sub { font-size: 14px; color: var(--text-secondary); margin-top: 4px; display: block; }

/* Camera Stage */
.camera-stage {
  width: calc(100% - 32px);
  height: 360rpx;
  margin: 0 16px;
  border-radius: var(--radius);
  overflow: hidden;
  background: #1a1a1a;
  position: relative;
}
.camera-stage.has-photo { height: auto; aspect-ratio: 1; }
.camera-overlay {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
}
.scan-frame {
  width: 200rpx; height: 200rpx;
  position: relative;
}
.scan-corner {
  position: absolute; width: 20px; height: 20px;
  border-color: rgba(255,255,255,.6); border-style: solid;
}
.tl { top:0; left:0; border-width: 2px 0 0 2px; border-radius: 4px 0 0 0; }
.tr { top:0; right:0; border-width: 2px 2px 0 0; border-radius: 0 4px 0 0; }
.bl { bottom:0; left:0; border-width: 0 0 2px 2px; border-radius: 0 0 0 4px; }
.br { bottom:0; right:0; border-width: 0 2px 2px 0; border-radius: 0 0 4px 0; }
.preview-full { width:100%; height:100%; }

/* Actions */
.action-area { padding: 0 16px; }
.action-row { display: flex; gap: 12px; padding: 0 16px; }
.action-row button { flex: 1; margin: 0; }
.upload-link {
  text-align: center; padding: 14px;
  color: var(--gold); font-size: 14px;
}

/* Error */
.error-toast {
  margin: 12px 16px; padding: 14px 20px;
  background: #FFF5F5; border: 1px solid #FDD;
  border-radius: var(--radius-sm); color: var(--red);
  font-size: 14px; text-align: center;
}

/* ===== Result ===== */
.result-section { margin-top: 8px; }

.result-hero {
  text-align: center; padding: 32px 20px 20px;
  position: relative;
}
.result-badge {
  display: inline-flex; flex-direction: column;
  align-items: center; justify-content: center;
  width: 64px; height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold), #A07D52);
  color: #FFF; margin-bottom: 16px;
  box-shadow: 0 4px 16px rgba(184,149,106,.35);
}
.badge-conf { font-size: 20px; font-weight: 800; line-height: 1; }
.badge-label { font-size: 10px; opacity: .85; }
.result-name { font-size: 30px; font-weight: 800; color: var(--text); display: block; }
.result-latin { font-size: 14px; color: var(--text-muted); font-style: italic; }

/* Info Strip */
.info-strip {
  display: flex; align-items: center; justify-content: center;
  padding: 16px; gap: 24px;
}
.info-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.info-icon { font-size: 22px; }
.info-label { font-size: 12px; color: var(--text-muted); }
.info-divider { width: 1px; height: 32px; background: var(--border); }

/* Overview */
.overview-text {
  font-size: 15px; color: var(--text-secondary);
  line-height: 1.8; display: block;
}

/* Section */
.section-title {
  font-size: 16px; font-weight: 700; color: var(--text);
  margin-bottom: 14px; display: block;
}

/* Param Grid */
.param-grid {
  display: flex; flex-wrap: wrap; gap: 8px;
}
.param-cell {
  flex: 1 1 45%;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 12px;
}
.param-label { font-size: 11px; color: var(--text-muted); display: block; margin-bottom: 2px; }
.param-value { font-size: 14px; color: var(--text); font-weight: 500; }

/* Candidates */
.candidate-row {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 0;
}
.cand-name { font-size: 14px; color: var(--text-secondary); min-width: 80px; }
.cand-bar-bg {
  flex: 1; height: 6px; background: var(--bg);
  border-radius: 3px; overflow: hidden;
}
.cand-bar-fill {
  height: 100%; background: var(--gold-light);
  border-radius: 3px;
}
.cand-pct { font-size: 13px; color: var(--gold); font-weight: 600; min-width: 36px; text-align: right; }

/* Result Actions */
.result-actions {
  display: flex; flex-direction: column;
  padding: 0 16px; gap: 10px;
}
.retake-link {
  text-align: center; padding: 12px;
  color: var(--text-muted); font-size: 14px;
}
