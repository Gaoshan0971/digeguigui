<!-- pages/species/species.wxml -->
<view class="page">
  <view class="search-bar">
    <input placeholder="搜索龟种..." bindinput="onSearch" class="search-input" />
  </view>

  <view wx:if="{{loading}}" class="loading-more">加载中...</view>

  <view class="species-grid">
    <view wx:for="{{list}}" wx:key="species_id" class="species-card" bindtap="goDetail" data-id="{{item.species_id}}">
      <view class="species-card-top">
        <text class="sp-name">{{item.name_cn}}</text>
        <text class="sp-latin">{{item.name_latin}}</text>
      </view>
      <view class="sp-meta">
        <text class="tag">{{item.family}}</text>
        <text class="tag tag-gold">{{'⭐'.repeat(item.difficulty)}}</text>
      </view>
    </view>
  </view>
</view>
