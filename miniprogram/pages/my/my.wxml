<view class="pg">
  <!-- 未登录 -->
  <view wx:if="{{!user}}" class="login-hero">
    <text class="login-icon">🐢</text>
    <text class="h1">滴个龟龟</text>
    <text class="text-secondary" style="margin:8px 0 24px;display:block">登录后查看我的藏品和血统</text>
    <button class="btn-primary" bindtap="login">微信一键登录</button>
  </view>

  <!-- 已登录 -->
  <view wx:if="{{user}}">
    <view class="profile-card card" style="text-align:center;margin-top:24px">
      <view class="avatar-md" style="margin:0 auto 12px"></view>
      <text class="h2" style="display:block">{{user.nickname}}</text>
      <text class="text-muted">{{user.role === 'breeder' ? '繁育者' : '龟友'}}</text>
    </view>

    <view class="menu-section">
      <view class="menu-item"><text>📦 我的藏品</text><text>›</text></view>
      <view class="menu-item"><text>🧬 我的繁育记录</text><text>›</text></view>
      <view class="menu-item"><text>⭐ 我的鉴赏</text><text>›</text></view>
      <view class="menu-item"><text>❤️ 我的点赞</text><text>›</text></view>
    </view>
  </view>
</view>
