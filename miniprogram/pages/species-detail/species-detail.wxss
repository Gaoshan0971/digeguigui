.pg { min-height:100vh; }
.sd-hero { text-align:center; padding:36px 20px 24px; }
.sd-icon { font-size:56px; display:block; margin-bottom:8px; }
.sd-name { font-size:30px; font-weight:800; color:var(--text); display:block; }
.sd-latin { font-size:14px; color:var(--text-muted); font-style:italic; margin:4px 0; display:block; }
.sd-tags { display:flex; justify-content:center; gap:8px; margin-top:12px; }

.trait-row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--border); }
.trait-key { font-size:14px; color:var(--text-secondary); }
.trait-val { font-size:14px; color:var(--text); font-weight:500; }

.param-grid { display:flex; flex-wrap:wrap; gap:8px; }
.param-cell { flex:1 1 45%; background:var(--bg); border-radius:var(--radius-sm); padding:12px; }
.param-label { font-size:11px; color:var(--text-muted); display:block; margin-bottom:2px; }
.param-value { font-size:14px; color:var(--text); font-weight:500; }

.thumb-grid { display:flex; flex-wrap:wrap; }
.thumb-img { width:32%; aspect-ratio:1; margin:2px; border-radius:8px; background:var(--bg); }

/* Tab */
.tab-row { display: flex; margin: 4px 16px 12px; background: var(--bg-card); border-radius: var(--radius-sm); overflow: hidden; box-shadow: var(--shadow-sm); }
.tab-item { flex: 1; text-align: center; padding: 12px; font-size: 14px; color: var(--text-secondary); transition: all .2s; }
.tab-item.active { background: var(--gold); color: #FFF; font-weight: 600; }

/* Price Ladder */
.price-ladder { position: relative; padding-left: 16px; }
.pl-step { position: relative; padding-bottom: 16px; }
.pl-dot { position: absolute; left: -20px; top: 6px; width: 10px; height: 10px; border-radius: 50%; background: var(--gold); }
.pl-dot.rare { background: #7C3AED; }
.pl-dot.uncommon { background: #2563EB; }
.pl-dot.legend { background: #DC2626; }
.pl-line { position: absolute; left: -16px; top: 18px; bottom: 0; width: 2px; background: var(--border); }
.pl-body { }
.pl-header { display: flex; align-items: center; gap: 8px; margin-bottom: 2px; }
.pl-label { font-size: 15px; font-weight: 700; color: var(--text); }
.pl-rarity { font-size: 10px; padding: 1px 6px; border-radius: 8px; background: #EDE9FE; color: #7C3AED; text-transform: uppercase; }
.pl-desc { font-size: 12px; color: var(--text-muted); display: block; }
.pl-price { font-size: 16px; font-weight: 800; color: var(--gold); margin-top: 4px; display: block; }

/* Gene List */
.gene-list { display: flex; flex-direction: column; gap: 6px; }
.gene-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; background: var(--bg); border-radius: var(--radius-sm); }
.gi-left { display: flex; flex-direction: column; }
.gi-symbol { font-size: 15px; font-weight: 700; color: var(--text); }
.gi-name { font-size: 12px; color: var(--text-muted); }
.gi-right { display: flex; gap: 6px; align-items: center; }
.gi-price { font-size: 12px; font-weight: 700; color: var(--gold); }
.gene-inherit { font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 600; }
.gene-inherit.recessive { background: #FEF9C3; color: #A16207; }
.gene-inherit.dominant { background: #DCFCE7; color: #166534; }
.gene-inherit.codominant { background: #DBEAFE; color: #1E40AF; }
.gene-inherit.polygenic { background: #F3E8FF; color: #7C3AED; }
.gene-cat { font-size: 11px; color: var(--text-muted); background: var(--bg-card); padding: 2px 6px; border-radius: 6px; }

/* Combo List */
.combo-list { display: flex; flex-direction: column; gap: 10px; }
.combo-item { padding: 10px 12px; background: var(--bg); border-radius: var(--radius-sm); border-left: 3px solid var(--gold); }
.combo-item.combo-rare { border-left-color: #7C3AED; background: #FAF5FF; }
.ci-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }
.ci-name { font-size: 15px; font-weight: 700; color: var(--text); }
.ci-price { font-size: 13px; font-weight: 700; color: var(--gold); }
.ci-formula { font-size: 11px; color: var(--gold); display: block; }
.ci-desc { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

.tag-dna { background: #EDE9FE; color: #7C3AED; font-weight: 600; }
.empty-morph { text-align: center; padding: 32px; }
