.pg { min-height:100vh; }
.sd-hero { text-align:center; padding:36px 20px 24px; }
.sd-icon { font-size:56px; display:block; margin-bottom:8px; }
.sd-name { font-size:30px; font-weight:800; color:var(--text); display:block; }
.sd-latin { font-size:14px; color:var(--text-muted); font-style:italic; margin:4px 0; display:block; }
.sd-tags { display:flex; justify-content:center; gap:8px; margin-top:12px; }

.trait-row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--border); }
.trait-key { font-size:14px; color:var(--text-secondary); }
.trait-val { font-size:14px; color:var(--text); font-weight:500; }

.param-grid { display:flex; flex-wrap:wrap; gap:8px; }
.param-cell { flex:1 1 45%; background:var(--bg); border-radius:var(--radius-sm); padding:12px; }
.param-label { font-size:11px; color:var(--text-muted); display:block; margin-bottom:2px; }
.param-value { font-size:14px; color:var(--text); font-weight:500; }

.thumb-grid { display:flex; flex-wrap:wrap; }
.thumb-img { width:32%; aspect-ratio:1; margin:2px; border-radius:8px; background:var(--bg); }
