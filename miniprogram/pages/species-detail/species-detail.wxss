.name { font-size:24px; color:#d4a853; font-weight:700; display:block; }
.latin { font-size:13px; color:#6a9a7a; display:block; margin:4px 0 8px; }
.diff { font-size:14px; color:#8ab89a; display:block; margin-bottom:8px; }
.desc { color:#b0c8b8; font-size:14px; line-height:1.6; display:block; margin-bottom:12px; }
.section { border-top:1px solid #1a3a2a; padding-top:12px; margin-top:12px; }
.stitle { font-size:15px; color:#d4a853; font-weight:600; display:block; margin-bottom:8px; }
.trait-item,.care-row { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #0d2518; }
.trait-key,.care-k { font-size:13px; color:#8ab89a; }
.trait-val,.care-v { font-size:13px; color:#e8e0c8; }
.section-title { font-size:16px; color:#d4a853; font-weight:600; padding:16px 16px 8px; }
.thumb-grid { display:flex; flex-wrap:wrap; padding:0 12px; }
.thumb { width:32%; aspect-ratio:1; margin:2px; border-radius:6px; background:#0a1a10; }
