.detail-img { width:100%; height:400rpx; background:#0a1a10; }
.d-name { font-size:18px; color:#d4a853; font-weight:600; }
.d-grade { font-size:16px; color:#d4a853; background:rgba(212,168,83,.15); padding:2px 8px; border-radius:4px; margin-left:8px; }
.d-cap { color:#b0c8b8; font-size:14px; display:block; margin-top:8px; }
.d-scores { display:flex; gap:8px; margin-top:8px; }
.score { font-size:12px; color:#8ab89a; background:#0d2518; padding:4px 8px; border-radius:4px; }
.app-item { padding:8px 0; border-bottom:1px solid #1a3a2a; }
.app-user { font-size:13px; color:#d4a853; display:block; }
.app-comment { font-size:14px; color:#b0c8b8; }
.comment-box { margin-top:12px; }
.comment-input { background:#0d2518; border-radius:8px; padding:10px; color:#e8e0c8; font-size:14px; }
