.pg { padding-bottom:30px; }
.img-swiper { width:100%; height:480rpx; background:var(--bg); }
.swiper-img { width:100%; height:100%; }

.grade-badge {
  font-size:20px; font-weight:800; color:var(--gold);
  background:var(--gold-bg); width:48px; height:48px;
  border-radius:50%; display:flex; align-items:center; justify-content:center;
}

.score-row { display:flex; gap:6px; margin-top:12px; }
.score-block { flex:1; text-align:center; background:var(--bg); border-radius:8px; padding:8px 4px; }
.score-num { font-size:18px; font-weight:700; color:var(--gold); display:block; }
.score-dim { font-size:10px; color:var(--text-muted); }

.appr-item { padding:12px 0; border-bottom:1px solid var(--border); }
.appr-user { font-size:14px; font-weight:600; color:var(--text); display:block; }
.appr-text { font-size:14px; color:var(--text-secondary); display:block; margin-top:4px; }

.comment-box { margin-top:16px; }
.comment-inp { background:var(--bg); border-radius:var(--radius-sm); padding:12px; font-size:14px; color:var(--text); }

/* 💰 AI品鉴 */
.ai-appraise-cta { margin:16px 0; padding:16px; background:linear-gradient(135deg,#FFF8F0,#FFFDF8); border-radius:var(--radius); border:1px dashed #D4A574; }
.ai-result-card { margin:16px 0; padding:16px; background:linear-gradient(135deg,#FFFDF5,#FFF8EC); border-radius:var(--radius); border:1px solid #E8D5B0; }
.ai-comment { margin-top:12px; padding:12px; background:var(--bg); border-radius:8px; font-size:13px; color:var(--text-secondary); line-height:1.7; }
.btn-gold { width:100%; background:linear-gradient(135deg,#B8956A,#D4A574); color:#fff; border-radius:var(--radius-sm); font-size:16px; font-weight:600; padding:14px; border:none; }
