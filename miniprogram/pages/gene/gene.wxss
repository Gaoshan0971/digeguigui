.pg { padding-bottom: 30px; }
.gh { text-align: center; padding: 32px 20px 20px; }
.gh-title { font-size: 26px; font-weight: 800; color: var(--text); display: block; }
.gh-sub { font-size: 13px; color: var(--text-muted); margin-top: 4px; display: block; }

.tab-row { display: flex; margin: 4px 16px 12px; background: var(--bg-card); border-radius: var(--radius-sm); overflow: hidden; box-shadow: var(--shadow-sm); }
.tab-item { flex: 1; text-align: center; padding: 12px; font-size: 14px; color: var(--text-secondary); transition: all .2s; }
.tab-item.active { background: var(--gold); color: #FFF; font-weight: 600; }

.species-card { display: flex; align-items: center; padding: 16px; margin: 0 16px 8px; background: var(--bg-card); border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); gap: 12px; }
.sc-left { width: 44px; height: 44px; background: var(--bg); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.sc-emoji { font-size: 22px; }
.sc-body { flex: 1; }
.sc-name { font-size: 16px; font-weight: 600; color: var(--text); }
.sc-latin { font-size: 12px; color: var(--text-muted); font-style: italic; margin: 2px 0; display: block; }
.sc-tags { margin-top: 4px; }
.sc-arrow { font-size: 22px; color: var(--text-muted); }

.breeding-card {  }
.br-name { font-size: 15px; font-weight: 600; color: var(--text); display: block; }
.br-count-badge { background: var(--gold-bg); color: var(--gold); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
