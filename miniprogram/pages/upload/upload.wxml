<view class="pg">
  <!-- 未提交 -->
  <block wx:if="{{!submitted}}">

    <!-- ===== 取景框（画廊风） ===== -->
    <view class="vf-box {{imgUrl ? 'has-photo' : ''}}" bindtap="chooseImage">
      <image wx:if="{{imgUrl}}" src="{{imgUrl}}" mode="aspectFill" class="vf-img" />
      <view wx:else class="vf-empty">
        <view class="vf-grid"></view>
        <text class="vf-icon">📷</text>
        <text class="vf-hint">拍摄龟背纹路</text>
      </view>
      <!-- 品种浮标 -->
      <view wx:if="{{speciesName}}" class="species-chip" catchtap="onSpeciesChange">
        <text>🐢 {{speciesName || '选择品种'}}</text>
        <text class="chip-arrow">›</text>
      </view>
    </view>

    <!-- ===== 批量计数器（工作室风） ===== -->
    <view wx:if="{{batchMode && batchCount > 0}}" class="counter-hero">
      <text class="counter-num">{{batchCount}}</text>
      <text class="counter-label">只已登记</text>
    </view>

    <!-- ===== 照片条（批量模式） ===== -->
    <scroll-view wx:if="{{batchMode && batchAnchors.length > 0}}" class="photo-strip" scroll-x>
      <block wx:for="{{batchAnchors}}" wx:key="anchor_id">
        <view class="strip-slot filled">
          <text style="font-size:20px;color:#7A9A9A">✓</text>
          <text style="font-size:10px;color:#B8956A;margin-top:4px">{{item.anchor_id.slice(-4)}}</text>
        </view>
      </block>
      <view class="strip-slot add-slot" bindtap="chooseImage">
        <text style="font-size:24px;color:#D4C4A8">+</text>
      </view>
    </scroll-view>

    <!-- ===== 信息卡片（证书房风） ===== -->
    <view class="info-card">
      <picker wx:if="{{!speciesId}}" mode="selector" range="{{speciesList}}" range-key="name_cn" bindchange="onSpeciesChange">
        <view class="info-row">
          <text class="info-lbl">品种</text>
          <text class="info-val gold">选择品种 ›</text>
        </view>
      </picker>
      <view wx:else class="info-row" bindtap="onSpeciesChange">
        <text class="info-lbl">品种</text>
        <text class="info-val gold">{{speciesName}}</text>
      </view>
      <input class="info-inp" placeholder="窝次/备注（如：2026春·第3窝）" value="{{caption}}" bindinput="e=>this.setData({caption:e.detail.value})" />
      <input class="info-inp" placeholder="所在城市" value="{{city}}" bindinput="e=>this.setData({city:e.detail.value})" style="margin-top:2px" />
    </view>

    <!-- ===== 批量开关 ===== -->
    <view wx:if="{{intent=='provenance'}}" class="batch-row" bindtap="toggleBatch">
      <view>
        <text class="batch-title">🔁 批量登记</text>
        <text class="batch-desc">同一窝连续拍照，信息一次填完</text>
      </view>
      <view class="toggle {{batchMode ? 'on' : ''}}"><view class="toggle-knob"></view></view>
    </view>

    <!-- ===== 锚定时间线（批量模式） ===== -->
    <view wx:if="{{batchMode && batchAnchors.length > 0}}" class="timeline">
      <block wx:for="{{batchAnchors}}" wx:key="anchor_id">
        <view class="tl-row">
          <view class="tl-dot"></view>
          <view class="tl-body">
            <text class="tl-name">🐢 {{item.species_name || speciesName}} #{{item.index}}</text>
            <text class="tl-id">{{item.anchor_id}}</text>
          </view>
          <text class="tl-time">刚刚</text>
        </view>
      </block>
    </view>

    <!-- ===== 邀请码（非批量时显示） ===== -->
    <view wx:if="{{intent=='provenance' && !batchMode && showInviteCode}}" class="info-card" style="margin-top:0">
      <input placeholder="输入邀请码 (TG-XXXXXX)" value="{{inviteCode}}" bindinput="e=>this.setData({inviteCode:e.detail.value.toUpperCase()})" class="info-inp" style="text-align:center;font-size:16px;letter-spacing:3px" maxlength="9" />
      <button class="btn-outline-sm" bindtap="verifyInviteCode" wx:if="{{inviteCode.length==9}}">验证邀请码</button>
      <text wx:if="{{inviteVerified}}" style="display:block;text-align:center;color:#7A9A9A;margin-top:8px;font-size:13px">✅ 邀请码有效 · 免费领证</text>
      <text wx:if="{{inviteError}}" style="display:block;text-align:center;color:#C46B6B;margin-top:8px;font-size:12px">{{inviteError}}</text>
    </view>

    <!-- ===== 操作按钮 ===== -->
    <block wx:if="{{batchMode}}">
      <button class="btn-gold" bindtap="submit" disabled="{{!imgUrl||!speciesId}}">
        📸 {{batchCount > 0 ? '继续拍（第'+(batchCount+1)+'只）' : '拍第一只'}}
      </button>
      <button wx:if="{{batchCount > 0}}" class="btn-outline" bindtap="finishBatch" style="margin-top:8px">
        ✅ 完成登记 · 共{{batchCount}}只
      </button>
    </block>
    <block wx:else>
      <button class="btn-gold" bindtap="submit" disabled="{{!imgUrl||!speciesId}}">
        {{intent=='provenance' ? (inviteVerified ? '📜 免费领证' : '📜 确认领证') : '发布到品鉴墙'}}
      </button>
    </block>

    <!-- 邀请码入口 + 福利提示 -->
    <view wx:if="{{intent=='provenance' && !batchMode}}" style="text-align:center;margin-top:8px">
      <text wx:if="{{!showInviteCode}}" style="font-size:12px;color:#B8956A" bindtap="toggleInviteCode">🎫 有达人邀请码？</text>
    </view>
    <view wx:if="{{intent=='provenance' && !batchMode}}" style="text-align:center;margin-top:6px">
      <text class="perk-text">🎁 繁育者认证通过即送 200 个免费锚定额度</text>
    </view>

  </block>

  <!-- ===== 单只成功：证书页 ===== -->
  <block wx:if="{{submitted && !batchDone}}">
    <view class="cert-page">
      <view class="cert-seal">印</view>
      <text class="cert-title">🎉 领证成功</text>
      <text class="cert-sub">{{speciesName}} · 已锚定上链</text>
      <text class="cert-id">{{anchorId}}</text>
      <text wx:if="{{remainingFree !== null}}" class="cert-remaining">🎁 剩余免费额度：{{remainingFree}} 次</text>
      <view class="cert-note">
        <text>🛡️ 出生锚定 · 龟纹AI识别 · 哈希链存证</text>
        <text style="margin-top:8px;font-size:13px;color:#8C7B6B">手写证明之外，多一份区块链认证</text>
      </view>
    </view>
    <button class="btn-gold" open-type="share">📤 晒到群里</button>
    <button class="btn-outline" bindtap="backHome" style="margin-top:8px">返回首页</button>
  </block>

  <!-- ===== 批量完成：汇总 ===== -->
  <block wx:if="{{batchDone}}">
    <view class="cert-page">
      <view class="cert-seal" style="width:60px;height:60px;font-size:20px">印</view>
      <text class="cert-title">🎉 批量登记完成</text>
      <text class="cert-sub">{{speciesName}} · 一窝{{batchCount}}只已全部上链</text>
      <view style="text-align:left;margin:20px 0;width:100%">
        <block wx:for="{{batchAnchors}}" wx:key="anchor_id">
          <view class="batch-result-row">
            <text>🐢 #{{item.index}} {{item.species_name || speciesName}}</text>
            <text class="batch-result-id">{{item.anchor_id}}</text>
          </view>
        </block>
      </view>
      <text wx:if="{{remainingFree !== null}}" class="cert-remaining">🎁 剩余免费额度：{{remainingFree}} 次</text>
    </view>
    <button class="btn-gold" open-type="share">📤 晒到群里：一窝{{batchCount}}只全部上户口！</button>
    <button class="btn-outline" bindtap="backHome" style="margin-top:8px">返回首页</button>
  </block>

  <!-- 邀请码小入口 -->
  <view wx:if="{{intent=='provenance' && !submitted && !batchMode && !showInviteCode}}" style="text-align:center;margin-top:8px">
    <text style="font-size:11px;color:#B8A99A">🛡️ 出生锚定 · 龟纹AI · 哈希链存证</text>
  </view>
</view>
