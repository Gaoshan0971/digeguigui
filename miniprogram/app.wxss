/* 全局样式 — 滴个龟龟 暗绿主题 */
page {
  background: #0d2518;
  color: #e8e0c8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 15px;
}

/* 通用卡片 */
.card {
  background: #132e1f;
  border-radius: 12px;
  padding: 16px;
  margin: 12px 16px;
  border: 1px solid #1a3a2a;
}

/* 按钮 */
.btn-primary {
  background: #d4a853;
  color: #1a3a2a;
  border-radius: 12px;
  padding: 14px;
  text-align: center;
  font-weight: 700;
  font-size: 16px;
  margin: 12px 16px;
}

.btn-primary:active {
  background: #c49a43;
  transform: scale(0.97);
}

.btn-outline {
  background: transparent;
  color: #d4a853;
  border: 2px solid #d4a853;
  border-radius: 12px;
  padding: 12px;
  text-align: center;
  font-weight: 600;
}

/* 文本 */
.text-gold { color: #d4a853; }
.text-green { color: #8ab89a; }
.text-muted { color: #6a9a7a; font-size: 13px; }

/* 布局 */
.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-wrap { display: flex; flex-wrap: wrap; }

/* 标签 */
.tag {
  display: inline-block;
  background: #1a3a2a;
  color: #8ab89a;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  margin: 2px;
}

.tag-gold {
  background: rgba(212,168,83,.15);
  color: #d4a853;
}

/* 头像 */
.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1a3a2a;
  overflow: hidden;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 20px;
  color: #6a9a7a;
  font-size: 13px;
}
